{
  "name": "profile-ivf-100k",
  "schema_version": 1,
  "artifact_dir": "artifacts/benchmark-profiles/profile-ivf-100k",
  "defaults": {
    "profile": "ec_ivf",
    "bits": 4,
    "seed": 42,
    "queries_limit": 100,
    "iterations": 100,
    "force_index": true,
    "sample_backend_memory": true,
    "memory_sample_interval_ms": 25,
    "pg": 18
  },
  "thresholds": [
    {
      "name": "quality-candidate-recall100-floor",
      "step": "recall100-candidates-w1000",
      "metric": "recall",
      "filters": {
        "nprobe": "96"
      },
      "field": "recall@k",
      "op": "gte",
      "value": 0.99
    },
    {
      "name": "quality-candidate-p50-budget-ms",
      "step": "latency-candidates-w1000",
      "metric": "latency",
      "filters": {
        "nprobe": "96"
      },
      "field": "p50",
      "op": "lte",
      "value": 15.0
    }
  ],
  "steps": [
    {
      "kind": "load",
      "name": "load-real100k-n128-w500",
      "tags": ["load", "ivf", "real100k", "n128", "w500"],
      "prefix": "profile_real100k_pqg8_n128",
      "corpus_file": "data/task31_m5_dbpedia_staged/ec_real_100k_corpus.tsv",
      "queries_file": "data/task31_m5_dbpedia_staged/ec_real_100k_queries.tsv",
      "manifest_file": "data/task31_m5_dbpedia_staged/ec_real_100k_manifest.json",
      "allow_manifest_mismatch": true,
      "reloptions": [
        "storage_format=pq_fastscan",
        "pq_group_size=8",
        "nlists=128",
        "nprobe=48",
        "rerank=heap_f32",
        "rerank_width=500"
      ],
      "log_file": "artifacts/benchmark-profiles/profile-ivf-100k/load-real100k-n128-w500.log"
    },
    {
      "kind": "recall",
      "name": "recall10-nprobe-sweep-w500",
      "tags": ["recall", "ivf", "real100k", "n128", "w500"],
      "prefix": "profile_real100k_pqg8_n128",
      "k": 10,
      "sweep": [40, 48, 56, 64, 80, 96],
      "rerank_width": 500,
      "truth_cache_file": "artifacts/benchmark-profiles/profile-ivf-100k/truth-real100k-k10.json",
      "log_output": "artifacts/benchmark-profiles/profile-ivf-100k/recall10-nprobe-sweep-w500.log"
    },
    {
      "kind": "latency",
      "name": "latency-nprobe-sweep-w500",
      "tags": ["latency", "ivf", "real100k", "n128", "w500"],
      "prefix": "profile_real100k_pqg8_n128",
      "k": 10,
      "sweep": [40, 48, 56, 64, 80, 96],
      "rerank_width": 500,
      "log_output": "artifacts/benchmark-profiles/profile-ivf-100k/latency-nprobe-sweep-w500.log"
    },
    {
      "kind": "recall",
      "name": "recall100-candidates-w500",
      "tags": ["recall", "ivf", "real100k", "n128", "w500", "k100"],
      "prefix": "profile_real100k_pqg8_n128",
      "k": 100,
      "sweep": [80, 96],
      "rerank_width": 500,
      "truth_cache_file": "artifacts/benchmark-profiles/profile-ivf-100k/truth-real100k-k100.json",
      "log_output": "artifacts/benchmark-profiles/profile-ivf-100k/recall100-candidates-w500.log"
    },
    {
      "kind": "recall",
      "name": "recall100-candidates-w1000",
      "tags": ["recall", "ivf", "real100k", "n128", "w1000", "k100"],
      "prefix": "profile_real100k_pqg8_n128",
      "k": 100,
      "sweep": [80, 96],
      "rerank_width": 1000,
      "truth_cache_file": "artifacts/benchmark-profiles/profile-ivf-100k/truth-real100k-k100.json",
      "log_output": "artifacts/benchmark-profiles/profile-ivf-100k/recall100-candidates-w1000.log"
    },
    {
      "kind": "latency",
      "name": "latency-candidates-w1000",
      "tags": ["latency", "ivf", "real100k", "n128", "w1000"],
      "prefix": "profile_real100k_pqg8_n128",
      "k": 10,
      "sweep": [80, 96],
      "rerank_width": 1000,
      "log_output": "artifacts/benchmark-profiles/profile-ivf-100k/latency-candidates-w1000.log"
    },
    {
      "kind": "storage",
      "name": "storage-real100k-n128",
      "tags": ["storage", "ivf", "real100k", "n128"],
      "prefix": "profile_real100k_pqg8_n128",
      "log_file": "artifacts/benchmark-profiles/profile-ivf-100k/storage-real100k-n128.log"
    },
    {
      "kind": "compare-pgvector",
      "name": "compare-pgvector-ivfflat-real100k-k10",
      "tags": ["compare", "pgvector", "ivfflat", "ivf", "real100k", "n128", "k10"],
      "prefix": "profile_real100k_pqg8_n128",
      "profile": "ec_ivf",
      "k": 10,
      "sweep": [40, 48, 56, 64, 80, 96],
      "rerank_width": 500,
      "pgvector_am": "ivfflat",
      "pgvector_lists": 128,
      "pgvector_maintenance_work_mem": "256MB",
      "rebuild": true,
      "log_file": "artifacts/benchmark-profiles/profile-ivf-100k/compare-pgvector-ivfflat-real100k-k10.log"
    },
    {
      "kind": "compare-pgvector",
      "name": "compare-pgvector-ivfflat-real100k-k100",
      "tags": ["compare", "pgvector", "ivfflat", "ivf", "real100k", "n128", "k100", "w1000"],
      "prefix": "profile_real100k_pqg8_n128",
      "profile": "ec_ivf",
      "k": 100,
      "sweep": [80, 96],
      "rerank_width": 1000,
      "pgvector_am": "ivfflat",
      "pgvector_lists": 128,
      "pgvector_maintenance_work_mem": "256MB",
      "log_file": "artifacts/benchmark-profiles/profile-ivf-100k/compare-pgvector-ivfflat-real100k-k100.log"
    },
    {
      "kind": "explain",
      "name": "explain-quality-candidate",
      "tags": ["explain", "ivf", "real100k", "n128", "w1000"],
      "prefix": "profile_real100k_pqg8_n128",
      "index_name": "profile_real100k_pqg8_n128_idx",
      "nprobe": 96,
      "rerank_width": 1000,
      "sql_file": "artifacts/benchmark-profiles/profile-ivf-100k/explain-quality-candidate.sql",
      "log_output": "artifacts/benchmark-profiles/profile-ivf-100k/explain-quality-candidate.log"
    }
  ]
}
