      "sweep": [8, 24],
      "rerank_width": 25,
      "log_output": "review/30623-spire-suite-config/artifacts/latency_real10k_spire_n32_w25_p8_24.log"
    },
    {
      "kind": "recall",
      "name": "recall-real10k-nprobe-sweep-w25",
      "tags": ["recall", "sweep", "real10k", "n32", "w25"],
      "prefix": "task30_spire_real10k_suite",
      "k": 10,
      "sweep": [8, 24],
      "rerank_width": 25,
      "truth_cache_file": "review/30623-spire-suite-config/artifacts/truth_real10k_spire_k10.json",
      "log_output": "review/30623-spire-suite-config/artifacts/recall_real10k_spire_n32_w25_p8_24.log"
    }
