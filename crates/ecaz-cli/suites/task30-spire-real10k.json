      "prefix": "task30_spire_real10k_suite",
      "log_file": "review/30623-spire-suite-config/artifacts/storage_real10k_spire_n32.log"
    },
    {
      "kind": "explain",
      "name": "explain-real10k-n32-p24-w25",
      "tags": ["explain", "planner", "real10k", "n32", "w25"],
      "prefix": "task30_spire_real10k_suite",
      "index_name": "task30_spire_real10k_suite_idx",
      "nprobe": 24,
      "rerank_width": 25,
      "sql_file": "review/30623-spire-suite-config/artifacts/explain_real10k_spire_n32_p24_w25.sql",
      "log_output": "review/30623-spire-suite-config/artifacts/explain_real10k_spire_n32_p24_w25.log"
    },
    {
      "kind": "latency",
      "name": "latency-real10k-nprobe-sweep-w25",
      "tags": ["latency", "sweep", "real10k", "n32", "w25"],
      "prefix": "task30_spire_real10k_suite",
