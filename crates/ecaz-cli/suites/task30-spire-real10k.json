{
  "name": "task30-spire-real10k",
  "schema_version": 1,
  "artifact_dir": "review/30623-spire-suite-config/artifacts",
  "defaults": {
    "profile": "ec_spire",
    "bits": 4,
    "seed": 42,
    "queries_limit": 100,
    "iterations": 100,
    "force_index": true,
    "sample_backend_memory": true,
    "memory_sample_interval_ms": 25,
    "pg": 18,
    "socket_dir": "/home/peter/.pgrx"
  },
  "steps": [
    {
      "kind": "load",
      "name": "load-real10k-turboquant-n32-w25",
