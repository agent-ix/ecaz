{
  "name": "task31-m5-ivf-100k",
  "schema_version": 1,
  "artifact_dir": "review/30178-task31-suite-runner-dry-run/artifacts",
  "defaults": {
    "profile": "ec_ivf",
    "bits": 4,
    "seed": 42,
    "queries_limit": 100,
    "iterations": 100,
    "force_index": true,
    "sample_backend_memory": true,
    "memory_sample_interval_ms": 25,
    "pg": 18,
    "socket_dir": "/Users/peter/.pgrx"
  },
  "thresholds": [
    {
      "name": "quality-candidate-recall100-floor",
      "step": "recall100-candidates-w1000",
      "metric": "recall",
      "field": "recall@k",
      "op": "gte",
      "value": 0.99
    },
    {
      "name": "quality-candidate-p50-budget-ms",
      "step": "latency-candidates-w1000",
      "metric": "latency",
      "field": "p50",
      "op": "lte",
      "value": 15.0
    }
  ],
  "steps": [
    {
      "kind": "load",
      "name": "load-real100k-n128-w500",
      "tags": ["load", "baseline", "100k", "n128", "w500"],
      "prefix": "task31_m5_real100k_pqg8_n128",
      "corpus_file": "data/task31_m5_dbpedia_staged/ec_hnsw_real_100k_corpus.tsv",
      "queries_file": "data/task31_m5_dbpedia_staged/ec_hnsw_real_100k_queries.tsv",
      "manifest_file": "data/task31_m5_dbpedia_staged/ec_hnsw_real_100k_manifest.json",
      "allow_manifest_mismatch": true,
      "reloptions": [
        "storage_format=pq_fastscan",
        "pq_group_size=8",
        "nlists=128",
        "nprobe=48",
        "rerank=heap_f32",
        "rerank_width=500"
      ],
      "log_file": "review/30178-task31-suite-runner-dry-run/artifacts/load_real100k_pqg8_n128_w500.log"
    },
    {
      "kind": "recall",
      "name": "recall10-nprobe-sweep-w500",
      "tags": ["recall", "recall10", "sweep", "100k", "n128", "w500"],
      "prefix": "task31_m5_real100k_pqg8_n128",
      "k": 10,
      "sweep": [40, 48, 56, 64, 80, 96],
      "rerank_width": 500,
      "truth_cache_file": "review/30178-task31-suite-runner-dry-run/artifacts/truth_real100k_n128_k10.json",
      "log_output": "review/30178-task31-suite-runner-dry-run/artifacts/recall10_real100k_pqg8_n128_w500_p40_48_56_64_80_96.log"
    },
    {
      "kind": "latency",
      "name": "latency-nprobe-sweep-w500",
      "tags": ["latency", "sweep", "100k", "n128", "w500"],
      "prefix": "task31_m5_real100k_pqg8_n128",
      "k": 10,
      "sweep": [40, 48, 56, 64, 80, 96],
      "rerank_width": 500,
      "log_output": "review/30178-task31-suite-runner-dry-run/artifacts/latency_real100k_pqg8_n128_w500_p40_48_56_64_80_96.log"
    },
    {
      "kind": "recall",
      "name": "recall100-candidates-w500",
      "tags": ["recall", "recall100", "candidate", "100k", "n128", "w500"],
      "prefix": "task31_m5_real100k_pqg8_n128",
      "k": 100,
      "sweep": [80, 96],
      "rerank_width": 500,
      "truth_cache_file": "review/30178-task31-suite-runner-dry-run/artifacts/truth_real100k_n128_k100.json",
      "log_output": "review/30178-task31-suite-runner-dry-run/artifacts/recall100_real100k_pqg8_n128_w500_p80_96.log"
    },
    {
      "kind": "recall",
      "name": "recall100-candidates-w1000",
      "tags": ["recall", "recall100", "candidate", "100k", "n128", "w1000"],
