      "sql_file": "review/30178-task31-suite-runner-dry-run/artifacts/explain_real100k_pqg8_n128_p96_w1000.sql",
      "log_output": "review/30178-task31-suite-runner-dry-run/artifacts/explain_real100k_pqg8_n128_p96_w1000.log"
