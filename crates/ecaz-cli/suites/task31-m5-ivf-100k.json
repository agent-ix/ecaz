      "log_output": "review/30178-task31-suite-runner-dry-run/artifacts/recall100_real100k_pqg8_n128_w1000_p80_96.log"
    },
    {
      "kind": "latency",
      "name": "latency-candidates-w1000",
      "tags": ["latency", "candidate", "100k", "n128", "w1000"],
      "prefix": "task31_m5_real100k_pqg8_n128",
      "k": 10,
      "sweep": [80, 96],
      "rerank_width": 1000,
      "log_output": "review/30178-task31-suite-runner-dry-run/artifacts/latency_real100k_pqg8_n128_w1000_p80_96.log"
