{
  "name": "task47-cross-am-gate-small",
  "schema_version": 1,
  "artifact_dir": "target/gates/cross-am-small",
  "defaults": {
    "bits": 4,
    "seed": 42,
    "queries_limit": 50,
    "force_index": true
  },
  "thresholds": [
    {
      "name": "hnsw-cross-am-floor",
      "step": "hnsw-small-k10",
      "metric": "recall",
      "field": "recall@k",
      "op": "gte",
      "value": 0.84
    },
    {
      "name": "diskann-cross-am-floor",
      "step": "diskann-small-k10",
      "metric": "recall",
      "field": "recall@k",
      "op": "gte",
      "value": 0.55
    },
    {
      "name": "hnsw-diskann-jaccard-report-floor",
      "step": "hnsw-diskann-consistency",
      "metric": "cross_am",
      "filters": { "pair": "hnsw~diskann" },
      "field": "jaccard@k",
      "op": "gte",
      "value": 0.1
    },
    {
      "name": "hnsw-diskann-kendall-valid-range",
      "step": "hnsw-diskann-consistency",
      "metric": "cross_am",
      "filters": { "pair": "hnsw~diskann" },
      "field": "kendall_tau@k",
      "op": "gte",
      "value": -1.0
    }
  ],
  "steps": [
    {
      "kind": "recall",
      "name": "hnsw-small-k10",
      "tags": ["cross-am", "small", "pr"],
      "prefix": "task47_gate_hnsw",
      "profile": "ec_hnsw",
      "k": 10,
      "sweep": [128],
      "truth_cache_file": "target/gates/cross-am-small/real10k-truth-k10.json",
      "log_output": "target/gates/cross-am-small/hnsw-real10k-k10.log",
      "predictions_output": "target/gates/cross-am-small/hnsw-real10k-k10-predictions.json"
    },
    {
      "kind": "recall",
      "name": "diskann-small-k10",
      "tags": ["cross-am", "small", "pr"],
      "prefix": "task47_gate_diskann",
      "profile": "ec_diskann",
      "k": 10,
      "sweep": [200],
      "truth_cache_file": "target/gates/cross-am-small/real10k-truth-k10.json",
      "log_output": "target/gates/cross-am-small/diskann-real10k-k10.log",
      "predictions_output": "target/gates/cross-am-small/diskann-real10k-k10-predictions.json"
    },
    {
      "kind": "cross-am",
      "name": "hnsw-diskann-consistency",
      "tags": ["cross-am", "small", "pr"],
      "inputs": [
        "hnsw=target/gates/cross-am-small/hnsw-real10k-k10-predictions.json",
        "diskann=target/gates/cross-am-small/diskann-real10k-k10-predictions.json"
      ],
      "k": 10,
      "log_output": "target/gates/cross-am-small/hnsw-diskann-consistency.log"
    }
  ]
}
