#!/usr/bin/env bash
# ecaz cloud — DB host bootstrap (Amazon Linux 2023, aarch64 / Graviton).
#
# Tagged for FR-045: install PG18, build ecaz from a passed git ref, attach
# data EBS at /dev/sdf, place PGDATA on it, run CREATE EXTENSION ecaz.
#
# Status: Bootstrap stub. The real build of pgrx + ecaz on Graviton is
# checkpoint 4. This script provisions the disk and Postgres scaffolding so
# checkpoints 3 (`ecaz cloud up`) can connect; checkpoint 4 fills in the
# extension build.

set -euxo pipefail

PGDATA=/var/lib/pgsql/18/data
# AL2023 installs PG18 binaries to /usr/bin (not the postgresql.org RPM
# /usr/pgsql-18/bin layout).
PG_BIN_DIR=/usr/bin
PG_CONFIG=/usr/bin/pg_config
DATA_DEV=/dev/nvme1n1   # EBS /dev/sdf maps to nvme1n1 on Nitro
ECAZ_REF='${ecaz_git_ref}'
ECAZ_URL='${ecaz_git_url}'
S3_BUCKET='${bucket}'
PROFILE='${profile}'

dnf -y update
dnf -y install --allowerasing \
  git gcc gcc-c++ make clang clang-devel llvm llvm-devel \
  openssl-devel readline-devel zlib-devel bzip2-devel \
  jq cmake pkgconfig perl
# Note: awscli v2 (`aws`) ships in the AL2023 base image; no dnf install needed.
# `parquet-tools` is not available in AL2023; the bootstrap flow does not use it.

# --- Postgres 18 -----------------------------------------------------------
# AL2023 ships PG18 as regular RPMs (not a dnf module). server-devel
# provides /usr/bin/pg_config which pgrx needs.
dnf -y install postgresql18-server postgresql18-contrib postgresql18-server-devel

# --- Mount data volume -----------------------------------------------------
if ! blkid "$DATA_DEV" >/dev/null 2>&1; then
  mkfs.xfs -f "$DATA_DEV"
fi
mkdir -p /var/lib/pgsql/18
echo "$DATA_DEV /var/lib/pgsql/18 xfs defaults,nofail 0 2" >> /etc/fstab
mount -a
chown -R postgres:postgres /var/lib/pgsql

# --- initdb if first boot --------------------------------------------------
if [ ! -s "$PGDATA/PG_VERSION" ]; then
  sudo -u postgres "$PG_BIN_DIR/initdb" -D "$PGDATA" --locale=C --encoding=UTF8
fi

cat > "$PGDATA/postgresql.auto.conf" <<EOF
listen_addresses = '*'
port = 5432
max_parallel_workers_per_gather = 4
max_parallel_workers = 8
work_mem = '64MB'
maintenance_work_mem = '512MB'
EOF
# shared_preload_libraries = 'ecaz' is appended below, AFTER the pgrx
# build installs ecaz.so. Setting it before the .so exists makes
# postgresql.service fail to start.

cat > "$PGDATA/pg_hba.conf" <<EOF
local all all                     trust
host  all all 127.0.0.1/32        trust
host  all all 10.42.0.0/16        trust
EOF

# AL2023 unit is `postgresql.service` with default PGDATA=/var/lib/pgsql/data.
# Drop-in overrides PGDATA to our EBS-backed location.
mkdir -p /etc/systemd/system/postgresql.service.d
cat > /etc/systemd/system/postgresql.service.d/pgdata.conf <<EOF
[Service]
Environment=PGDATA=$PGDATA
EOF
systemctl daemon-reload
systemctl enable postgresql
systemctl start postgresql

# --- Rust toolchain (for cargo pgrx) --------------------------------------
sudo -u postgres bash -c '
  curl --proto "=https" --tlsv1.2 -sSf https://sh.rustup.rs \
    | sh -s -- -y --default-toolchain stable --profile minimal
  source $HOME/.cargo/env
  cargo install --locked cargo-pgrx@^0.17 --features pg18
  cargo pgrx init --pg18 /usr/bin/pg_config
'

# --- Build & install ecaz extension at the requested ref ------------------
sudo -u postgres bash -lc "
  set -eux
  export PATH=\$HOME/.cargo/bin:\$PATH
  rm -rf /var/lib/pgsql/build
  mkdir -p /var/lib/pgsql/build
  cd /var/lib/pgsql/build
  git clone $ECAZ_URL ecaz
  cd ecaz
  git checkout $ECAZ_REF
  cargo pgrx install --release --pg-config /usr/bin/pg_config
"

# Now safe to enable shared_preload_libraries.
cat >> "$PGDATA/postgresql.auto.conf" <<EOF
shared_preload_libraries = 'ecaz'
EOF
systemctl restart postgresql
sleep 3

sudo -u postgres psql -c 'CREATE EXTENSION IF NOT EXISTS ecaz;'

# --- Tag readiness in S3 so `ecaz cloud install` can poll -----------------
aws s3 cp - "s3://$S3_BUCKET/state/$PROFILE/db-ready" <<<"$(date -Is)"
