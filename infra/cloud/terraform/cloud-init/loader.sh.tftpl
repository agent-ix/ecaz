#!/usr/bin/env bash
# ecaz cloud — loader host bootstrap (Amazon Linux 2023, aarch64).
#
# Tagged for FR-047. Installs prerequisites and clones ecaz so SSM-exec'd
# corpus stage/load runs can use the existing `ecaz corpus prepare` and
# `ecaz corpus load` code paths against the DB's private IP.

set -euxo pipefail

ECAZ_REF='${ecaz_git_ref}'
ECAZ_URL='${ecaz_git_url}'
S3_BUCKET='${bucket}'

dnf -y update
dnf -y install --allowerasing \
  git gcc gcc-c++ make clang clang-devel llvm llvm-devel \
  openssl-devel readline-devel zlib-devel bzip2-devel \
  postgresql18 postgresql18-server-devel \
  jq cmake pkgconfig perl
# Note: awscli v2 (`aws`) ships in the AL2023 base image; no dnf install needed.
# postgresql18-server-devel is required because `cargo build -p ecaz-cli`
# pulls in the ecaz lib crate, which transitively requires pgrx-pg-sys —
# pgrx-pg-sys needs pg_config + a `cargo pgrx init`'d PGRX_HOME at build
# time. Without server-devel + init the build dies with
# "Error: $PGRX_HOME does not exist".

useradd -m loader || true

sudo -u loader bash -c '
  curl --proto "=https" --tlsv1.2 -sSf https://sh.rustup.rs \
    | sh -s -- -y --default-toolchain stable --profile minimal
  source $HOME/.cargo/env
  cargo install --locked cargo-pgrx@^0.17
  cargo pgrx init --pg18 /usr/bin/pg_config
'

sudo -u loader bash -lc "
  set -eux
  export PATH=\$HOME/.cargo/bin:\$PATH
  rm -rf \$HOME/ecaz
  git clone $ECAZ_URL \$HOME/ecaz
  cd \$HOME/ecaz
  git checkout $ECAZ_REF
  cargo build --release -p ecaz-cli
"
# Install the binary as root (the loader user can't write to
# /usr/local/bin); the build runs as the loader user above.
install -Dm755 /home/loader/ecaz/target/release/ecaz /usr/local/bin/ecaz

aws s3 cp - "s3://$S3_BUCKET/state/loader/ready" <<<"$(date -Is)"
