+impl SpireVacuumIndexRelation {
+    unsafe fn new(relation: pg_sys::Relation) -> Self {
+        Self { relation }
+    }
+
+    fn root_control(self) -> SpireRootControlState {
+        // SAFETY: this wrapper is constructed only for the live SPIRE index
