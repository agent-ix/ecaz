+#[derive(Debug)]
+struct ProbeCandidateAccumulator {
+    limit: Option<usize>,
+    best_by_heap_tid: *mut HashMap<ItemPointer, EcIvfScoredCandidate>,
+    retained: BinaryHeap<CandidateHeapEntry>,
+}
+
+impl ProbeCandidateAccumulator {
+    fn new(
+        limit: Option<usize>,
+        best_by_heap_tid: *mut HashMap<ItemPointer, EcIvfScoredCandidate>,
+    ) -> Self {
+        Self {
+            limit,
+            best_by_heap_tid,
+            retained: limit
+                .map(BinaryHeap::with_capacity)
+                .unwrap_or_else(BinaryHeap::new),
+        }
+    }
+
+    fn posting_score_cannot_enter(&mut self, score: f32) -> bool {
+        let Some(limit) = self.limit else {
+            return false;
+        };
+        if limit == 0 {
+            return true;
+        }
+        let Some(worst) = self.current_worst_retained(limit) else {
+            return false;
+        };
+        score.total_cmp(&worst.score) == Ordering::Greater
+    }
+
+    fn push(&mut self, candidate: EcIvfScoredCandidate) -> bool {
+        let best_by_heap_tid = unsafe { &mut *self.best_by_heap_tid };
+        if let Some(existing) = best_by_heap_tid.get_mut(&candidate.heap_tid) {
+            let improved = candidate_cmp(&candidate, existing) == Ordering::Less;
+            if improved {
+                *existing = candidate;
+            }
+            if improved {
+                self.push_retained(candidate);
+            }
+            return true;
+        }
+
+        if self.candidate_cannot_enter(candidate) {
+            return false;
+        }
+        best_by_heap_tid.insert(candidate.heap_tid, candidate);
+        self.push_retained(candidate);
+        false
+    }
+
+    fn into_ranked_candidates(self) -> Vec<EcIvfScoredCandidate> {
+        let best_by_heap_tid = unsafe { &*self.best_by_heap_tid };
+        collect_ranked_probe_candidates(best_by_heap_tid.values().copied(), self.limit)
+    }
+
+    fn candidate_cannot_enter(&mut self, candidate: EcIvfScoredCandidate) -> bool {
+        let Some(limit) = self.limit else {
+            return false;
+        };
+        if limit == 0 {
+            return true;
+        }
+        self.current_worst_retained(limit)
+            .is_some_and(|worst| candidate_cmp(&candidate, &worst) != Ordering::Less)
+    }
+
+    fn push_retained(&mut self, candidate: EcIvfScoredCandidate) {
+        let Some(limit) = self.limit else {
+            return;
+        };
+        if limit == 0 {
+            return;
+        }
+        if self.current_worst_retained(limit).is_none() || self.retained.len() < limit {
+            self.retained.push(CandidateHeapEntry { candidate });
+            return;
+        }
+        if self
+            .current_worst_retained(limit)
+            .is_some_and(|worst| candidate_cmp(&candidate, &worst) == Ordering::Less)
+        {
+            self.retained.pop();
+            self.retained.push(CandidateHeapEntry { candidate });
+        }
+    }
+
+    fn current_worst_retained(&mut self, limit: usize) -> Option<EcIvfScoredCandidate> {
+        while self.retained.len() >= limit {
+            let Some(worst) = self.retained.peek() else {
+                return None;
+            };
+            if self
+                .best_by_heap_tid()
+                .get(&worst.candidate.heap_tid)
+                .is_some_and(|current| same_scored_candidate(current, &worst.candidate))
+            {
+                return Some(worst.candidate);
+            }
+            self.retained.pop();
+        }
+        None
+    }
+
+    fn best_by_heap_tid(&self) -> &HashMap<ItemPointer, EcIvfScoredCandidate> {
+        unsafe { &*self.best_by_heap_tid }
+    }
+}
